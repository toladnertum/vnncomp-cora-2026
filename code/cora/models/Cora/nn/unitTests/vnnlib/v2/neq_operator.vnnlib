(vnnlib-version <2.0>)

(declare-network N
    (declare-input  X real [2])
    (declare-output Y real [1])
)

; != expands to two disjunct branches: X[0] < 0.5 or X[0] > 0.5
(assert (!= X[0] 0.5))
(assert (>= X[0] 0.0))
(assert (<= X[0] 1.0))
(assert (>= X[1] 0.0))
(assert (<= X[1] 1.0))

(assert (<= Y[0] 2.0))
