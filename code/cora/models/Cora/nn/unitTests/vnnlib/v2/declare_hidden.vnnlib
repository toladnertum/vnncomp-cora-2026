(vnnlib-version <2.0>)

(declare-network N
    (declare-input  X real [3])
    (declare-hidden H real [4] "hidden_layer_0")
    (declare-output Y real [2])
)

(assert (>= X[0] 0.0))
(assert (<= X[0] 1.0))
(assert (>= X[1] 0.0))
(assert (<= X[1] 1.0))
(assert (>= X[2] 0.0))
(assert (<= X[2] 1.0))

(assert (<= Y[0] 2.0))
