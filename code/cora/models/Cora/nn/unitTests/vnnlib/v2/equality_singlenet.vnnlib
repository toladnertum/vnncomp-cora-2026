; Single-network spec exercising the == operator.

(vnnlib-version <2.0>)

(declare-network N
    (declare-input  X real [3])
    (declare-output Y real [2])
)

; Two open ranges and one fixed input
(assert (<= X[0]  0.5))
(assert (>= X[0] -0.5))
(assert (<= X[1]  1.0))
(assert (>= X[1]  0.0))
(assert (== X[2]  0.25))

; Output unsafe set
(assert (<= Y[0] Y[1]))
