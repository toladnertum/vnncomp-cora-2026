(vnnlib-version <2.0>)

(declare-network N
    (declare-input  Xinit real [2] initialized)
    (declare-input  Xfree real [3])
    (declare-output Y real [2])
)

(assert (>= Xinit[0] -1.0))
(assert (<= Xinit[0]  1.0))
(assert (>= Xinit[1] -1.0))
(assert (<= Xinit[1]  1.0))
(assert (>= Xfree[0]  0.0))
(assert (<= Xfree[0]  1.0))
(assert (>= Xfree[1]  0.0))
(assert (<= Xfree[1]  1.0))
(assert (>= Xfree[2]  0.0))
(assert (<= Xfree[2]  1.0))

(assert (<= Y[0] 2.0))
